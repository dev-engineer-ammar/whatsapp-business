PORT=5000
ADMIN_API_KEY=choose_a_private_admin_key
ADMIN_USERNAME=admin
ADMIN_PASSWORD=choose_a_strong_admin_password
ADMIN_SESSION_SECRET=choose_a_long_random_session_secret
MONGODB_URI=mongodb://127.0.0.1:27017/whatsapp-commerce

WHATSAPP_PROVIDER=wati
WATI_BASE_URL=https://live-mt-server.wati.io/10198605
WATI_ACCESS_TOKEN=your_wati_bearer_token
WHATSAPP_VERIFY_TOKEN=choose_a_verify_token

# Only needed when WHATSAPP_PROVIDER=cloud
WHATSAPP_TOKEN=your_meta_cloud_api_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_API_VERSION=v25.0

EASYPAISA_PAYMENT_BASE_URL=https://easypaisa.example.com/pay
EASYPAISA_STORE_ID=your_store_id
EASYPAISA_HASH_KEY=your_hash_key
EASYPAISA_CALLBACK_URL=https://your-domain.com/api/webhooks/payment

DEFAULT_ORDER_AMOUNT=1000
DEFAULT_CURRENCY=PKR
